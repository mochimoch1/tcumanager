<script type="text/javascript">

$(document).ready(function(){
function searchCourses(target) {
    var div;
    var input;

    if (target == 'left') {
        div = $('div#courses_list_left');
        input = $('#search_courses_left');
    } else {
        div = $('div#courses_list_right');
        input = $('#search_courses_right');
    }

    var ul = $('ul.courseList', div);
    var li = $('> li', ul);
    var i;
    var j;

    input.keyup(function() {
        if (this.value.length == 0) {
            for (i = 0; i < li.length; i++) { $(li[i]).show(); }
            $('#no_course').remove();
            return;
        }
        var value = this.value.toString()
                .replace(/\\/g, '\\\\')
                .replace(/\^/g, '\\^')
                .replace(/\$/g, '\\$')
                .replace(/\./g, '\\.')
                .replace(/\*/g, '\\*')
                .replace(/\+/g, '\\+')
                .replace(/\?/g, '\\?')
                .replace(/\(/g, '\\(')
                .replace(/\)/g, '\\)')
                .replace(/\[/g, '\\[')
                .replace(/\]/g, '\\]')
                .replace(/\{/g, '\\{')
                .replace(/\}/g, '\\}')
                .replace(/\|/g, '\\|')
                .replace(/\=/g, '\\=')
                .replace(/\!/g, '\\!')
                .replace(/\</g, '\\<')
                .replace(/\>/g, '\\>')
                .replace(/\:/g, '\\:')
                .replace(/\-/g, '\\-')
                .split(/[\x20\u3000]/)

        var re = [];

        for (i = 0; i < value.length; i++) {
            re.push(new RegExp(value[i], 'i'));
        }

        for (i = 0; i < li.length; i++) {
            var target_text = $('a', li[i]).text();

            if (target_text.match(re[0])) {
                $(li[i]).show();

                for (j = 1; j < re.length; j++) {
                    if ( !target_text.match(re[j]) ) {
                        $(li[i]).hide();
                    }
                }
            } else {
                $(li[i]).hide();
            }
        }

        if ($(':visible', li).length == 0) {
            if ($('#no_course').size() == 0 && li.length > 0) {
                div.prepend($('<p style="margin: 1em">').attr('id', 'no_course').text('コースが見つかりませんでした'));
            }
        } else {
            $('#no_course').remove();
        }
    });
}

searchCourses('left');
searchCourses('right');



});

</script>
